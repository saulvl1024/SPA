# ============================================================
#  Plantilla de variables de entorno. Copia a .env y completa.
#  NUNCA subas .env a git (ya está en .gitignore).
# ============================================================

# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@127.0.0.1:5433/seren_spa"

# Entorno: "development" o "production".
# En "production" se exige CORS_ORIGINS y se bloquean peticiones sin origen.
NODE_ENV="development"

# Servidor
PORT=4001

# Token de sesión JWT — OBLIGATORIO. Mínimo 16 caracteres.
# Genera uno seguro con:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="genera-un-secreto-largo-y-aleatorio-aqui"

# Orígenes permitidos para CORS (separados por coma). SOLO la app debe poder llamar al backend.
# En producción es OBLIGATORIO definir el/los dominio(s) reales de la app.
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# WhatsApp Cloud API (Meta) — si se dejan vacías, los envíos se simulan (modo demo).
# Obtén estos valores en tu panel de Meta for Developers. NO los compartas.
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
WHATSAPP_API_VERSION="v25.0"

# Token de verificación del webhook de WhatsApp (lo defines tú, debe coincidir en Meta).
WA_WEBHOOK_VERIFY_TOKEN="define-un-token-de-verificacion"

# Envíos automáticos diarios (cron interno). Define la hora (0-23) para activarlo.
WA_AUTO_HOUR=9
WA_REMIND_TODAY="true"
WA_REMIND_TOMORROW="true"
WA_BIRTHDAY="true"
# Plantillas aprobadas en Meta (nombre exacto) e idioma
WA_TEMPLATE_REMINDER="recordatorio_cita"
WA_TEMPLATE_BIRTHDAY="feliz_cumple"
WA_TEMPLATE_LANG="es_MX"
